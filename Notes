New-ServicePrincipal -AppId "d6a69784-e545-4cf9-b6bd-b0b4a939bdad" -ObjectId "80a6bffa-c12a-4195-83d9-db8d1a5c8739" -DisplayName "Intellimation"

##
# For mail access (replace with the appropriate role based on your needs)
New-ManagementRoleAssignment -App "Intellimation" -Role "Application Mail.ReadWrite" -CustomResourceScope "SRT_Reporting_Mailbox"


#  Find existing management scopes 

Get-ManagementRoleAssignment -RoleAssignee <service principal object id>

# Example
Get-ManagementRoleAssignment -RoleAssignee 6a17c80c-52cb-4b43-b3d8-72d597211232


###

New-ManagementRoleAssignment -App "OpsDataMailAutomation" -Role "Application Mail.Send" -CustomResourceScope "OpsDataAdminAutomation"


# get service principal permissions per mailbox (aka "management scope")

Get-ManagementRoleAssignment -RoleAssignee <ServicePrincipal_ObjectId> | Select-Object Name, Role, CustomResourceScope


# example 
Get-ManagementRoleAssignment -RoleAssignee f0f58597-617b-444d-9d6a-6f410c3a93ea | Select-Object Name, Role, CustomResourceScope





