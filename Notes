# powershell 7 connect and authenticate to mggraph via client secret 
#https://www.reddit.com/r/Intune/comments/1dpeq5c/how_to_connect_using_powershell_and_client_secret/

$tenantId = "IDHERE"
$clientId = "IDHERE"
$clientSecret = ConvertTo-SecureString "CLIENTSECRETHERE" -AsPlainText -Force
$credential = New-Object System.Management.Automation.PSCredential($clientId, $clientSecret)
Connect-MgGraph -NoWelcome -ClientSecretCredential $credential -TenantId $tenantId


### intune LAPS local admin config

1. entra ID admin center > devices > device settings "enable microsoft entra local admin password solution (LAPS)" > "Yes"

2. Intune admin center > Endpoint Security > Account Protection > Creat Policy > "local admin password solution (LAPS)" > configure settings

Other notes

- To configure automatic LAPS account creation per device disalbe "Administrator account name" and enable "Automatic account management"


