Graph mail API Powershell 

# Install module
Install-Module Microsoft.Graph.Mail -Scope CurrentUser

OR 

Install-Module Microsoft.Graph.Mail -Scope AllUsers

# All mail objects
Get-MgUserMessage -UserId user@domain.com -All

# Messages from specific folder
# Using well-known folder names (Inbox, Drafts, SentItems, DeletedItems, etc.)
Get-MgUserMailFolderMessage -UserId user@domain.com -MailFolderId "Inbox" -All
 
# Using folder ID
Get-MgUserMailFolderMessage -UserId user@domain.com -MailFolderId "AAMkAGVm..." -All

# Get single message with properties
Get-MgUserMessage -UserId user@domain.com -MessageId $messageId -Property "subject,body,bodyPreview,uniqueBody"


#Filter by sender
Get-MgUserMessage -UserId user@domain.com -Filter "from/emailAddress/address eq 'sender@domain.com'"

#Filter by date range
Get-MgUserMailFolderMessage -UserId user@domain.com -MailFolderId "Inbox" `
  -Filter "receivedDateTime ge 2024-01-01T00:00:00Z and receivedDateTime le 2024-12-31T23:59:59Z"

# Filter unread messages
Get-MgUserMessage -UserId user@domain.com -Filter "isRead eq false"

# Full-text search
Get-MgUserMessage -UserId user@domain.com -Search "project update"

# Sort and limit results
Get-MgUserMailFolderMessage -UserId user@domain.com -MailFolderId "Inbox" `
  -Sort "receivedDateTime DESC" -Top 25

# Get body with specific properties
$message = Get-MgUserMessage -UserId user@domain.com -MessageId $messageId `
  -Property "subject,body,bodyPreview"

# Get plain text body (no HTML tags)
powershell# Request text format using headers
$message = Get-MgUserMessage -UserId user@domain.com -MessageId $messageId `
  -Property "subject,body" ` # Optional 
  -Headers @{ "Prefer" = 'outlook.body-content-type="text"' }

List Folders
powershell# All folders
Get-MgUserMailFolder -UserId user@domain.com -All

# Specific folder with child folders
Get-MgUserMailFolder -UserId user@domain.com -MailFolderId "Inbox"
Send Email
powershell$params = @{
    Message = @{
        Subject = "Test Email"
        Body = @{
            ContentType = "HTML"
            Content = "<p>Email body</p>"
        }
        ToRecipients = @(
            @{
                EmailAddress = @{
                    Address = "recipient@domain.com"
                }
            }
        )
    }
}

Send-MgUserMail -UserId user@domain.com -BodyParameter $params
Move/Delete Messages
# Move to folder
Move-MgUserMessage -UserId user@domain.com -MessageId $messageId -DestinationId $folderId

# Soft delete (to Recoverable Items)
Remove-MgUserMessage -UserId user@domain.com -MessageId $messageId

# Update properties
Update-MgUserMessage -UserId user@domain.com -MessageId $messageId -IsRead $true
Common Property Access
$message = Get-MgUserMessage -UserId user@domain.com -MessageId $messageId

$message.Subject
$message.From.EmailAddress.Address
$message.ToRecipients.EmailAddress.Address
$message.ReceivedDateTime
$message.HasAttachments
$message.InternetMessageId
$message.Body.Content          # Full body
$message.BodyPreview          # First 255 chars
$message.ParentFolderId

## Example: Extract most recent email from list, view body contents

$messages = get-mgusermessage -userid rparke@arrowmarkpartners.com -Property "subject,body,bodypreview,uniquebody" -Headers @{ "Prefer" = 'outlook.body-content-type="text"' }

$messagebody = $messages[0].Body

